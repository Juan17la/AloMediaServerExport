# Server Configuration
PORT=3001

# GPU Acceleration (set to "true" to enable auto-detection)
# Supported encoders: h264_nvenc, h264_qsv, h264_vaapi
ENABLE_GPU=false

# Maximum concurrent export jobs
MAX_CONCURRENT_JOBS=2

# Maximum segment workers per job
MAX_SEGMENT_WORKERS=4

# Job timeout in milliseconds (default: 30 minutes)
JOB_TIMEOUT_MS=1800000

# Completed file cleanup age in milliseconds (default: 1 hour)
CLEANUP_AGE_MS=3600000

# Temp directory for assets and outputs
TEMP_DIR=./tmp

# CORS allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173